# Copy this file to .env.local and fill in real values. Never commit
# .env.local — it's gitignored.

# --- Supabase -------------------------------------------------------------
# Same project as Mindcafe/frontend — this page reuses that backend
# (products, cart, orders, pickup locations, Razorpay/Shiprocket edge
# functions) instead of standing up a second one.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Razorpay (client-side) -------------------------------------------------
# Publishable key id only — safe for the browser. The secret key and
# webhook secret live in Supabase Edge Function secrets, never here.
NEXT_PUBLIC_RAZORPAY_KEY_ID=